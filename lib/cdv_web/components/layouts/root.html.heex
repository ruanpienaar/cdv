<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <title>CDV — Erlang Crash Dump Viewer</title>
    <style>
      :root {
        --bg:        #0d0f14;
        --surface:   #161921;
        --border:    #2a2f3d;
        --accent:    #e05c3a;
        --accent2:   #4ec9b0;
        --muted:     #5a6375;
        --text:      #d4d8e2;
        --text-dim:  #8891a4;
        --red:       #f47067;
        --green:     #4ec9b0;
        --yellow:    #e5c07b;
        --blue:      #61afef;
        --purple:    #c678dd;
        --font-mono: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
        --font-sans: 'Inter', 'Segoe UI', system-ui, sans-serif;
        --radius:    4px;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body { height: 100%; background: var(--bg); color: var(--text); font-family: var(--font-sans); font-size: 14px; }
      a { color: var(--blue); text-decoration: none; }
      a:hover { color: var(--accent2); text-decoration: underline; }
      code, pre, .mono { font-family: var(--font-mono); }
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: var(--bg); }
      ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

      nav.topbar {
        display: flex; align-items: center;
        background: var(--surface); border-bottom: 1px solid var(--border);
        padding: 0 1rem; height: 44px;
        position: sticky; top: 0; z-index: 100;
      }
      nav.topbar .logo {
        font-family: var(--font-mono); font-size: 13px; font-weight: 700;
        color: var(--accent); letter-spacing: 2px; margin-right: 2rem;
        text-transform: uppercase;
      }
      nav.topbar .dump-name {
        font-family: var(--font-mono); font-size: 11px; color: var(--text-dim);
        overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 300px;
      }
      nav.topbar .spacer { flex: 1; }
      nav.topbar .nav-link {
        font-family: var(--font-mono); font-size: 11px; font-weight: 500;
        color: var(--text-dim); padding: 0 0.75rem; height: 44px;
        display: flex; align-items: center; border-bottom: 2px solid transparent;
        transition: color 0.15s, border-color 0.15s;
        text-decoration: none; text-transform: uppercase; letter-spacing: 0.5px;
        white-space: nowrap;
      }
      nav.topbar .nav-link:hover { color: var(--text); text-decoration: none; }
      nav.topbar .nav-link.active { color: var(--accent2); border-bottom-color: var(--accent2); }
      nav.topbar .truncated-badge {
        font-family: var(--font-mono); font-size: 10px;
        background: #3a1a0d; color: var(--accent); border: 1px solid var(--accent);
        border-radius: 3px; padding: 2px 8px; margin-left: 1rem;
      }

      main.content { padding: 1.5rem 2rem; max-width: 1600px; margin: 0 auto; }

      .page-title {
        font-family: var(--font-mono); font-size: 16px; font-weight: 700;
        color: var(--text); margin-bottom: 1.5rem;
        display: flex; align-items: center; gap: 0.5rem;
      }
      .page-title::before {
        content: ''; display: inline-block; width: 3px; height: 18px;
        background: var(--accent); border-radius: 2px;
      }

      .cdv-table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: 12px; }
      .cdv-table thead th {
        background: var(--surface); color: var(--text-dim); font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.5px; font-size: 10px;
        padding: 8px 12px; text-align: left; border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }
      .cdv-table thead th.sortable { cursor: pointer; user-select: none; }
      .cdv-table thead th.sortable:hover { color: var(--text); }
      .cdv-table thead th.sorted { color: var(--accent2); }
      .cdv-table tbody tr { border-bottom: 1px solid rgba(42,47,61,0.5); transition: background 0.1s; }
      .cdv-table tbody tr:hover { background: rgba(78,201,176,0.04); }
      .cdv-table tbody td { padding: 6px 12px; color: var(--text); }
      .cdv-table .num { text-align: right; color: var(--text-dim); }
      .cdv-table .hi  { color: var(--red); }
      .cdv-table .med { color: var(--yellow); }

      .kv-grid { display: grid; grid-template-columns: 220px 1fr; gap: 1px; background: var(--border); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 1.5rem; }
      .kv-grid .kv-key { background: var(--surface); padding: 8px 14px; font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); font-weight: 600; text-transform: uppercase; letter-spacing: 0.3px; }
      .kv-grid .kv-val { background: var(--bg); padding: 8px 14px; font-family: var(--font-mono); font-size: 12px; color: var(--text); word-break: break-all; }

      .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 1rem; }
      .card-title { font-family: var(--font-mono); font-size: 11px; font-weight: 700; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.75rem; }

      .badge { display: inline-block; font-family: var(--font-mono); font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.5px; }
      .badge-running  { background: rgba(78,201,176,0.15);  color: var(--green);  border: 1px solid rgba(78,201,176,0.3); }
      .badge-waiting  { background: rgba(97,175,239,0.1);   color: var(--blue);   border: 1px solid rgba(97,175,239,0.25); }
      .badge-exiting  { background: rgba(244,112,103,0.12); color: var(--red);    border: 1px solid rgba(244,112,103,0.3); }
      .badge-garbing  { background: rgba(229,192,123,0.12); color: var(--yellow); border: 1px solid rgba(229,192,123,0.3); }
      .badge-other    { background: rgba(90,99,117,0.2);    color: var(--muted);  border: 1px solid rgba(90,99,117,0.3); }

      .search-box { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); font-family: var(--font-mono); font-size: 12px; padding: 6px 12px; width: 280px; outline: none; }
      .search-box:focus { border-color: var(--accent2); }
      .search-box::placeholder { color: var(--muted); }

      .table-toolbar { display: flex; align-items: center; gap: 1rem; margin-bottom: 0.75rem; }
      .row-count { font-family: var(--font-mono); font-size: 11px; color: var(--muted); margin-left: auto; }

      .flash-error { background: rgba(244,112,103,0.1); border: 1px solid rgba(244,112,103,0.3); color: var(--red); padding: 10px 16px; border-radius: var(--radius); font-family: var(--font-mono); font-size: 12px; margin-bottom: 1rem; }

      .stack-pre { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1rem; font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); overflow-x: auto; white-space: pre; max-height: 400px; overflow-y: auto; }

      .idle-center { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 60vh; gap: 1rem; }
    </style>
    <script phx-track-static type="text/javascript" src={~p"/assets/phoenix.min.js"}></script>
    <script phx-track-static type="text/javascript" src={~p"/assets/phoenix_live_view.js"}></script>
    <script phx-track-static type="text/javascript" src={~p"/assets/app.js"}></script>
  </head>
  <body class="h-full">
    <%= @inner_content %>
  </body>
</html>